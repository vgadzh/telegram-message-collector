APP_ENV=local
APP_LOG_LEVEL=debug
APP_NODE_ID=node-1

HTTP_HOST=0.0.0.0
HTTP_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tgcollector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET=secret
JWT_ACCESS_TOKEN_TTL=1h

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxx

# --- AUTHENTICATION ---
ADMIN_LOGIN=admin

# Bcrypt hash for the initial admin account.
# WARNING: Always use SINGLE QUOTES ('') to prevent bash/zsh from evaluating '$' symbols.
ADMIN_PASSWORD_HASH='change-me'